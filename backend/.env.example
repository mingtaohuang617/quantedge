# QuantEdge backend 环境变量模板
# 复制为 .env 后填入真实值；.env 已在 .gitignore，不会被提交

# ─── iTick (https://itick.org) ────────────────────────
# 免费档可用，注册后在控制台获取
ITICK_API_KEY=

# ─── Tushare (https://tushare.pro) ───────────────────
# 注册免费，控制台 → 个人主页 → 接口TOKEN
# A 股 120 积分够用；港股 / 美股日 K 需 2000+ 积分
TUSHARE_TOKEN=

# ─── Futu OpenD (可选，仅港股/A股) ─────────────────────
# 默认本机 OpenD：127.0.0.1:11111；如未运行则自动降级到 yfinance
# FUTU_HOST=127.0.0.1
# FUTU_PORT=11111

# ─── FRED (https://fredaccount.stlouisfed.org/apikey) ─
# 美联储 St. Louis Fed 宏观时间序列。Phase 1 宏观因子库依赖。
# 注册免费、无限额（合理使用）；申请后即时下发 32 位 hex key。
FRED_API_KEY=

# ─── Finnhub (https://finnhub.io) ─────────────────────
# US 股 fundamentals enrich：PE / PB / 股息率 / ROE / D/E
# 免费 tier：60 calls/min；跑 12k 美股 ~3.3 小时
# 用法：python -m backend.universe.enrich_us_finnhub
FINNHUB_API_KEY=

# ─── DeepSeek (https://platform.deepseek.com) ─────────
# 所有 LLM 端点依赖（backend/llm.py 11 个高阶函数 + server.py 12 个 /api/llm/* 端点）：
#   summary / backtest-narrate / journal-structure / explain-score /
#   monthly-review / parse-strategy / 10x-thesis / value-thesis /
#   stock-gene-explain / macro-narrative / health / stats
# 注册 → 创建 API key；deepseek-chat 模型很便宜（~$0.14/1M tokens）。
# 不设此项时 LLM 端点会返回 503，主功能不受影响。
DEEPSEEK_API_KEY=
# 可选：默认 deepseek-chat；复杂场景可切 deepseek-reasoner（慢但更深）
# DEEPSEEK_MODEL=deepseek-chat
