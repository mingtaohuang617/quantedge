# Vercel production 环境变量模板。
# 在 Vercel Dashboard → Settings → Environment Variables 添加（不要 commit 真实值）。
# 本地 dev 不需要这些（vite proxy 走 backend FastAPI）。

# ─── LLM (DeepSeek) ─────────────────────────────────────
# 用途：/api/llm/10x-thesis、/api/llm/match-supertrend、
#       /api/llm/rank-candidates、/api/llm/generate-keywords
# 获取：https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=

# ─── Vercel KV (Upstash Redis) ──────────────────────────
# 启用方式：Vercel Dashboard → Storage → Create Database → KV → Connect
# 启用后这两个变量会被 vercel 自动注入到所有 environments。
# 本地 dev 不需要（业务走 Python backend）。
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── 自定义域名（可选）───────────────────────────────────
# 如果用了非默认域名（不是 *.vercel.app），把 hostname 加这里，
# 否则 referer 白名单会拒掉来自该域名的请求。逗号分隔。
QUANTEDGE_ALLOWED_HOSTS=

# ─── universe self-fetch 兜底（可选）─────────────────────
# serverless function 自调 /data/universe/*.json 时，默认走 VERCEL_URL；
# 私有部署或自定义域名可指定完整 base URL（含 protocol）。
QUANTEDGE_PUBLIC_BASE=
